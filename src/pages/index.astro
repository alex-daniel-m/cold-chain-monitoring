<script>
	document.addEventListener("DOMContentLoaded", () => {

		/**
		 * 
		 * Common Data
		 * 
		 */
		let thresholdSections: number = 0;
		let thresholdCardContent: number = 0;
		const width = window.innerWidth;

		/**
		 * 
		 * LandingPage scroll to top
		 * 
		 */
		
		const hero = document.querySelector("#welcome");
		const buttonScrollToTop = document.querySelector("#scrollToTop");
		if(hero && buttonScrollToTop){
			const observerHero = new IntersectionObserver((entries) => {
				entries.forEach(entry => {
					if(entry.isIntersecting){
						buttonScrollToTop.classList.remove('visible');
					}
					else{
						buttonScrollToTop.classList.add('visible');
					}
				});
			}, {
				threshold: 0
			});
			observerHero.observe(hero);
		}

		/**
		 * 
		 * LandingPage sections (without header)
		 * 
		 */

		thresholdSections = width < 1024 ? 0.1 : 0.2;

		const sections = document.querySelectorAll(".reveal-section");
		const observerSections = new IntersectionObserver((entries) => {
			entries.forEach(entry => {
				if (entry.isIntersecting) {
					entry.target.classList.add("visible");
					observerSections.unobserve(entry.target); // solo anima una vez
				}
			});
			
		}, {
			threshold: thresholdSections
		});

		sections.forEach(el => observerSections.observe(el));


		/**
		 * 
		 * LandingPage nav and sections (include header)
		 * 
		 */

		if(width >= 1280){
			const navLinks = document.querySelectorAll(".nav a");
			const sectionByNavLink = document.querySelectorAll("header[id], section[id]");
			const observerNav = new IntersectionObserver((entries) => {
				entries.forEach(entry => {
					if (entry.isIntersecting) {
						navLinks.forEach(link => link.classList.remove("active"));
	
						const id = entry.target.getAttribute("id");
						const activeLink = document.querySelector(
							`.nav a[href$="#${id}"]`
						);
						if (activeLink) {
							activeLink.classList.add("active");
						}
					}
				});
			}, {
				threshold: 0.3
			});
			sectionByNavLink.forEach(section => observerNav.observe(section as HTMLElement));
		}


		/**
		 * 
		 * LandingPage card images
		 * 
		 */
		
		const revealImages = document.querySelectorAll(".reveal-img");
		const observerImages = new IntersectionObserver((entries) => {
			entries.forEach(entry => {
				if (entry.isIntersecting) {
					entry.target.classList.add("visible");
					observerImages.unobserve(entry.target); // solo anima una vez
				}
			});
		}, {
			threshold: 0.9
		});
		revealImages.forEach(img => observerImages.observe(img));
		

		/**
		 * 
		 * LandingPage card content
		 * 
		 */

		thresholdCardContent = width < 1024 ? 0.4 : 0.9;

		const cardContents = document.querySelectorAll(".reveal-right");
		const observerCardContents = new IntersectionObserver((entries) => {
			entries.forEach(entry => {
				if(entry.isIntersecting){
					entry.target.classList.add("visible");
					observerCardContents.unobserve(entry.target); // solo anima una vez
				}
			});
		}, {
			threshold: thresholdCardContent
		});

		cardContents.forEach(el => observerCardContents.observe(el));

		/**
		 * 
		 * Contact Form
		 * 
		 */
		const form = document.getElementById("idContactForm") as HTMLFormElement;
		form.addEventListener("submit", (event) => {
			event.preventDefault();
			window.location.href = "/thank-you";
		});
});
</script>